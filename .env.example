# Oracle 19c - tnsnames.ora 의 DEV 항목으로 접속
DATABASE_URL=oracle+cx_oracle://계정명:비밀번호@DEV

# 앱 시작 시 SQLAlchemy create_all 실행 여부 (Oracle 운영 권장: false)
AUTO_CREATE_TABLES=false

# tnsnames.ora 가 위치한 디렉터리 (파일명 제외)
TNS_ADMIN=C:\Oracle\product\11.2.0\client\network\admin

# Oracle 클라이언트 BIN 디렉터리 (cx_Oracle 라이브러리 탐색 경로)
ORACLE_CLIENT_LIB=C:\Oracle\product\11.2.0\client\BIN

# tnsnames.ora 참조 항목 (변경 금지)
# DEV =
#   (DESCRIPTION =
#     (ADDRESS_LIST =
#       (ADDRESS = (PROTOCOL = TCP)(HOST = 192.168.1.100)(PORT = 9889))
#     )
#     (CONNECT_DATA =
#       (SERVICE_NAME = skr)
#     )
#   )
